rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'xanderwiles@gmail.com';
    }

    match /ideas/{ideaId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}
